# =============================================================
# P2P Chat App — environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================

# ---- Google OAuth2 ----
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add http://localhost/auth/google/callback as an authorised redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- JWT ----
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-256-bit-secret

# ---- PostgreSQL ----
POSTGRES_USER=chat
POSTGRES_PASSWORD=changeme-db-password
POSTGRES_DB=chatdb

# ---- Redis ----
# No password set by default in the compose service.
# To add auth: append `:password@` to the URL.
# REDIS_URL is constructed by docker-compose from individual vars;
# override here only if pointing to an external Redis.
# REDIS_URL=redis://redis:6379

# ---- MinIO (object storage) ----
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme-minio-password
MINIO_BUCKET=avatars

# ---- TURN server ----
# Must match static-auth-secret in coturn/turnserver.conf
TURN_SECRET=dev-turn-secret

# ---- Frontend ----
# The origin the React app is served from (used for CORS).
# In prod, set this to your domain: https://yourdomain.com
FRONTEND_ORIGIN=http://localhost

# ---- Dev / test overrides ----
# Set DEV_AUTH_ENABLED=true to expose POST /auth/dev-login (Playwright / local dev)
# Never enable in production.
DEV_AUTH_ENABLED=false
