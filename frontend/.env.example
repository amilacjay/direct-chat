# =============================================================
# Frontend build-time vars (Vite)
# Copy to .env.development (local dev) or .env.production (deploy).
#
# Vite bakes every VITE_* var into the JS bundle at BUILD time, so:
#   • changing a value requires a rebuild
#   • these values are PUBLIC (visible in the shipped bundle) — never put
#     secrets here
# =============================================================

# Backend API origin.
#   Production: leave empty so requests stay same-origin behind nginx.
#   Local dev:  http://localhost:8000
VITE_API_URL=

# 'true' exposes the dev-login form on the landing page (Playwright / local dev).
# Never enable in production.
VITE_DEV_AUTH=false

# Donation wallet addresses (public). Leave empty to hide that coin.
# Both empty = the "Support Direct" button is hidden entirely.
VITE_DONATE_XMR=
VITE_DONATE_BTC=
